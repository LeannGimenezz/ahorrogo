# AhorroGO Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Backend API URL
VITE_API_URL=http://localhost:8000/api/v1

# RSK Network Configuration
VITE_RSK_RPC_URL=https://public-node.testnet.rsk.co
VITE_RSK_CHAIN_ID=31
VITE_RSK_NETWORK_NAME=RSK Testnet
VITE_RSK_EXPLORER_URL=https://explorer.testnet.rsk.co

# Beexo Wallet Configuration
VITE_BEEXO_DEEPLINK=beexo://
VITE_BEEXO_PACKAGE=com.beexo.wallet

# Topykus Protocol (RSK Testnet)
VITE_TROPYKUS_COMPTROLLER=0x7de1ade...

# Feature Flags
VITE_MOCK_DATA=false
VITE_ENABLE_BLOCKCHAIN=true